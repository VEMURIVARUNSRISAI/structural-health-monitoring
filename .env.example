# ── Application ────────────────────────────────────────────
APP_ENV=development
LOG_LEVEL=INFO
API_HOST=0.0.0.0
API_PORT=8000

# ── Database (matches the docker-compose Postgres service) ─
DATABASE_URL=postgresql+asyncpg://shm_user:shm_pass@localhost:5432/shm_db
DATABASE_SYNC_URL=postgresql://shm_user:shm_pass@localhost:5432/shm_db

# ── AWS (fill in during Part 9 — leave blank until then) ───
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET_NAME=shm-drone-images
SQS_QUEUE_URL=

# ── ML models ──────────────────────────────────────────────
YOLOV8_WEIGHTS_PATH=ml/weights/yolov8_codebrim.pt
YOLOV9_WEIGHTS_PATH=ml/weights/yolov9_codebrim.pt
CONFIDENCE_THRESHOLD=0.35
IOU_THRESHOLD=0.45
MLFLOW_TRACKING_URI=http://localhost:5000

# ── ACI 318 severity thresholds ────────────────────────────
# A normalized severity score below LOW_MAX = Low, below MODERATE_MAX = Moderate,
# at or above MODERATE_MAX = Critical. Calibrated in Part 8.
SEVERITY_LOW_MAX=0.50
SEVERITY_MODERATE_MAX=0.75